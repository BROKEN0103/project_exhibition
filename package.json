{
    "name": "full-stack-app",
    "version": "1.0.2",
    "scripts": {
        "dev": "concurrently \"npm run dev --prefix frontend\" \"npm run dev --prefix backend\"",
        "install-all": "concurrently \"npm install --prefix frontend\" \"npm install --prefix backend\"",
        "build": "cd frontend && next build"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "next": "16.1.6",
        "react": "^19",
        "react-dom": "^19"
    }
}